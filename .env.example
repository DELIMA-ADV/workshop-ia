# ⚠️ IMPORTANTE: Este arquivo é apenas um template!
# Não comite credenciais reais neste arquivo.
# Copie para .env e preencha com suas credenciais.
# NO VERCEL: configure em Settings → Environment Variables

# ── Supabase (frontend + proxy backend) ─────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── E-mail via Resend ────────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Domínio verificado no Resend. Sem isso, usa onboarding@resend.dev (só testes)
RESEND_FROM_EMAIL=workshop@seudominio.com.br

# ── WhatsApp via Evolution API ───────────────────────────────────
EVOLUTION_API_URL=http://seu-servidor:8080/message/sendText/INSTANCIA
EVOLUTION_API_KEY=sua_api_key_aqui

# ── Painel Admin ─────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=admin123
